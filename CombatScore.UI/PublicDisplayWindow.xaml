<Window x:Class="CombatScore.UI.PublicDisplayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:CombatScore.UI.Converters"
        WindowState="Maximized"
        Background="#0B0B0B">

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility"/>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
        </Style>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="82"/>
        </Grid.RowDefinitions>

        <Border Background="Black" CornerRadius="8">
            <Grid Margin="20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Image Source="Assets/logo.jpg" Height="52" Margin="0,0,20,0"/>
                    <TextBlock Text="4COMBAT" FontSize="32" FontWeight="Bold"/>
                </StackPanel>
                <TextBlock Grid.Column="1" Text="{Binding MatText}" Foreground="#FFD600" FontSize="34" FontWeight="Bold" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <Border Grid.Row="1" Grid.RowSpan="2" Background="#101010" CornerRadius="8" Visibility="{Binding IsPanelReleased, Converter={StaticResource InverseBoolToVisibility}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <Image Source="Assets/logo.jpg" Width="520" Margin="0,0,0,35"/>
                <TextBlock Text="{Binding MatText}" Foreground="#FFD600" FontSize="32" FontWeight="Bold" HorizontalAlignment="Center"/>
                <TextBlock Text="AGUARDANDO CONFIGURAÇÃO DA LUTA" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,20,0,0"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" Margin="0,16" Visibility="{Binding IsPanelReleased, Converter={StaticResource BoolToVisibility}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3.2*"/>
                <ColumnDefinition Width="1.15*"/>
            </Grid.ColumnDefinitions>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Background="#0D47A1" CornerRadius="8" Margin="0,0,12,10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="82"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Margin="26,4" VerticalAlignment="Center">
                            <TextBlock Text="{Binding BlueName}" FontSize="32" FontWeight="Bold" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"/>
                            <TextBlock Text="{Binding BlueTeam}" FontSize="18" FontWeight="Bold" Margin="0,2,0,0" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                        <UniformGrid Grid.Row="1" Columns="3">
                            <Border Background="#F1F5F9" Margin="3">
                                <StackPanel VerticalAlignment="Center" Margin="0,0,0,0">
                                    <TextBlock Text="PONTUAÇÃO GERAL" Foreground="#111" FontSize="19" FontWeight="Bold" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding BlueScore, StringFormat={}{0:00}}" Foreground="#0D47A1" FontSize="128" FontWeight="Bold" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <Border Background="#FFD600" Margin="3">
                                <StackPanel VerticalAlignment="Center" Margin="0,0,0,0">
                                    <TextBlock Text="VANTAGEM" Foreground="#111" FontSize="19" FontWeight="Bold" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding BlueAdvantage, StringFormat={}{0:00}}" Foreground="Black" FontSize="128" FontWeight="Bold" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <Border Background="#D71920" Margin="3">
                                <StackPanel VerticalAlignment="Center" Margin="0,0,0,0">
                                    <TextBlock Text="PUNIÇÕES" Foreground="White" FontSize="19" FontWeight="Bold" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding BluePenalty, StringFormat={}{0:00}}" Foreground="White" FontSize="128" FontWeight="Bold" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </UniformGrid>
                    </Grid>
                </Border>

                <Border Grid.Row="1" Background="White" CornerRadius="8" Margin="0,10,12,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="82"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Margin="26,4" VerticalAlignment="Center">
                            <TextBlock Text="{Binding RedName}" Foreground="#111" FontSize="32" FontWeight="Bold" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"/>
                            <TextBlock Text="{Binding RedTeam}" Foreground="#333" FontSize="18" FontWeight="Bold" Margin="0,2,0,0" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                        <UniformGrid Grid.Row="1" Columns="3">
                            <Border Background="#F1F5F9" Margin="3">
                                <StackPanel VerticalAlignment="Center" Margin="0,0,0,0">
                                    <TextBlock Text="PONTUAÇÃO GERAL" Foreground="#111" FontSize="19" FontWeight="Bold" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding RedScore, StringFormat={}{0:00}}" Foreground="#111" FontSize="128" FontWeight="Bold" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <Border Background="#FFD600" Margin="3">
                                <StackPanel VerticalAlignment="Center" Margin="0,0,0,0">
                                    <TextBlock Text="VANTAGEM" Foreground="#111" FontSize="19" FontWeight="Bold" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding RedAdvantage, StringFormat={}{0:00}}" Foreground="Black" FontSize="128" FontWeight="Bold" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <Border Background="#D71920" Margin="3">
                                <StackPanel VerticalAlignment="Center" Margin="0,0,0,0">
                                    <TextBlock Text="PUNIÇÕES" Foreground="White" FontSize="19" FontWeight="Bold" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding RedPenalty, StringFormat={}{0:00}}" Foreground="White" FontSize="128" FontWeight="Bold" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </UniformGrid>
                    </Grid>
                </Border>
            </Grid>

            <StackPanel Grid.Column="1">
                <Border Background="Black" CornerRadius="8" Height="290">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="TEMPO RESTANTE" FontSize="26" FontWeight="Bold" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding TimeText}" Foreground="#39FF14" FontSize="112" FontWeight="Bold" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding Status}" Foreground="#39FF14" FontSize="19" FontWeight="Bold" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
                <Border Background="#161616" CornerRadius="8" Margin="0,16,0,0" Padding="22">
                    <StackPanel>
                        <TextBlock Text="AZUL" Foreground="#66A3FF" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding BlueName}" FontSize="28" FontWeight="Bold" TextAlignment="Center" TextWrapping="Wrap" HorizontalAlignment="Center"/>
                        <TextBlock Text="VS" Foreground="#FFD600" FontSize="34" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,25,0,25"/>
                        <TextBlock Text="{Binding RedName}" FontSize="28" FontWeight="Bold" TextAlignment="Center" TextWrapping="Wrap" HorizontalAlignment="Center"/>
                        <TextBlock Text="BRANCO" Foreground="White" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>

        <Border Grid.Row="2" Background="Black" CornerRadius="8" Visibility="{Binding IsPanelReleased, Converter={StaticResource BoolToVisibility}}">
            <Grid Margin="18,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.4*"/>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="1.4*"/>
                </Grid.ColumnDefinitions>

                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="CATEGORIA" FontSize="16"/>
                    <TextBlock Text="{Binding Category}" Foreground="#FFD600" FontSize="24" FontWeight="Bold" TextTrimming="CharacterEllipsis"/>
                </StackPanel>

                <StackPanel Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="FASE" FontSize="16" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding Phase}" Foreground="#FFD600" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                </StackPanel>

                <StackPanel Grid.Column="2" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock Text="STATUS" FontSize="16" HorizontalAlignment="Right"/>
                    <TextBlock Text="{Binding Status}" Foreground="#39FF14" FontSize="24" FontWeight="Bold" HorizontalAlignment="Right" TextTrimming="CharacterEllipsis"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.RowSpan="3" Background="#E6000000" Visibility="{Binding ShowChampion, Converter={StaticResource BoolToVisibility}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="1400">
                <TextBlock Text="{Binding ResultMode}" Foreground="#FFD600" FontSize="90" FontWeight="Bold" HorizontalAlignment="Center"/>
                <TextBlock Text="{Binding ChampionText}" FontSize="88" FontWeight="Bold" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap"/>
                <TextBlock Text="{Binding ChampionTeam}" Foreground="#FFD600" FontSize="32" FontWeight="Bold" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap" Margin="0,18,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
