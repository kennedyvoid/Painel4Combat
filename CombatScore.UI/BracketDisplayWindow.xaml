<Window x:Class="CombatScore.UI.BracketDisplayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="4Combat - Chaves do Campeonato"
        WindowState="Maximized"
        Background="#0B0B0B">

    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="95"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Background="Black" CornerRadius="8">
            <Grid Margin="24,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Image Source="Assets/logo.jpg" Height="58" Margin="0,0,20,0"/>
                    <TextBlock Text="4COMBAT" Foreground="White" FontSize="44" FontWeight="Bold"/>
                </StackPanel>

                <TextBlock Grid.Column="1" Text="CHAVES DO CAMPEONATO" Foreground="#FFD600" FontSize="34" FontWeight="Bold" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" Margin="0,18,0,0">
            <ItemsControl x:Name="BracketItems">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Width="560" Height="285" Background="#151515" BorderBrush="#333" BorderThickness="1" CornerRadius="8" Margin="10" Padding="18">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="58"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="38"/>
                                </Grid.RowDefinitions>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="{Binding Numero, StringFormat=LUTA {0}}" Foreground="#FFD600" FontSize="24" FontWeight="Bold"/>
                                        <TextBlock Text="{Binding Fase}" Foreground="White" FontSize="16"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" Text="{Binding Status}" Foreground="#39FF14" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
                                </Grid>

                                <Border Grid.Row="1" Background="#0D47A1" CornerRadius="6" Margin="0,6">
                                    <StackPanel Margin="12,6">
                                        <TextBlock Text="{Binding LutadorAzul}" Foreground="White" FontSize="26" FontWeight="Bold"/>
                                        <TextBlock Text="{Binding AcademiaAzul}" Foreground="White" FontSize="18"/>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Row="2" Background="White" CornerRadius="6" Margin="0,6">
                                    <StackPanel Margin="12,6">
                                        <TextBlock Text="{Binding LutadorBranco}" Foreground="#111" FontSize="26" FontWeight="Bold"/>
                                        <TextBlock Text="{Binding AcademiaBranco}" Foreground="#333" FontSize="18"/>
                                    </StackPanel>
                                </Border>

                                <Grid Grid.Row="3">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition/>
                                        <ColumnDefinition/>
                                        <ColumnDefinition/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding Categoria}" Foreground="#FFD600" FontSize="17" FontWeight="Bold"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Faixa}" Foreground="#FFD600" FontSize="17" FontWeight="Bold" HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="{Binding Sexo}" Foreground="#FFD600" FontSize="17" FontWeight="Bold" HorizontalAlignment="Right"/>
                                </Grid>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Window>
