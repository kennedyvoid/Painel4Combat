<Window x:Class="CombatScore.UI.MatConfigWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="760"
        Height="900"
        Background="#101010"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style TargetType="TextBlock"><Setter Property="Foreground" Value="White"/></Style>
        <Style TargetType="TextBox">
            <Setter Property="FontSize" Value="18"/><Setter Property="Padding" Value="8"/><Setter Property="Margin" Value="0,5,0,12"/>
            <Setter Property="Background" Value="#181818"/><Setter Property="Foreground" Value="White"/><Setter Property="BorderBrush" Value="#444"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Foreground" Value="White"/><Setter Property="FontWeight" Value="Bold"/><Setter Property="FontSize" Value="15"/>
            <Setter Property="Padding" Value="10"/><Setter Property="Margin" Value="4"/><Setter Property="BorderThickness" Value="0"/>
        </Style>
    </Window.Resources>

    <ScrollViewer>
        <StackPanel Margin="22">
            <TextBlock Text="{Binding MatText}" Foreground="#FFD600" FontSize="34" FontWeight="Bold"/>
            <TextBlock Text="CONFIGURAÇÃO / OPERADOR" FontSize="20" FontWeight="Bold" Margin="0,0,0,18"/>

            <TextBlock Text="Nome Azul"/>
            <TextBox Text="{Binding BlueName, UpdateSourceTrigger=PropertyChanged}"/>
            <TextBlock Text="Academia / Equipe Azul"/>
            <TextBox Text="{Binding BlueTeam, UpdateSourceTrigger=PropertyChanged}"/>
            <TextBlock Text="Nome Branco"/>
            <TextBox Text="{Binding RedName, UpdateSourceTrigger=PropertyChanged}"/>
            <TextBlock Text="Academia / Equipe Branco"/>
            <TextBox Text="{Binding RedTeam, UpdateSourceTrigger=PropertyChanged}"/>
            <TextBlock Text="Categoria"/>
            <TextBox Text="{Binding Category, UpdateSourceTrigger=PropertyChanged}"/>
            <TextBlock Text="Fase"/>
            <TextBox Text="{Binding Phase, UpdateSourceTrigger=PropertyChanged}"/>

            <Border Height="1" Background="#333" Margin="0,10,0,18"/>

            <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
                <Border Background="#0D47A1" CornerRadius="8" Padding="14" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="AZUL" FontSize="26" FontWeight="Bold"/>
                        <TextBlock Text="{Binding BlueScore, StringFormat=Pontuação geral: {0}}" FontSize="20"/>
                        <UniformGrid Columns="3">
                            <Button Content="+2" Background="#063B8E" Click="Blue2_Click"/><Button Content="+3" Background="#063B8E" Click="Blue3_Click"/><Button Content="+4" Background="#063B8E" Click="Blue4_Click"/>
                            <Button Content="-2" Background="#333" Click="BlueMinus2_Click"/><Button Content="-3" Background="#333" Click="BlueMinus3_Click"/><Button Content="-4" Background="#333" Click="BlueMinus4_Click"/>
                        </UniformGrid>
                        <TextBlock Text="{Binding BlueAdvantage, StringFormat=Vantagens: {0}}" FontSize="20" Margin="0,12,0,0"/>
                        <UniformGrid Columns="2"><Button Content="+ V" Background="#D79C22" Click="BlueAdvPlus_Click"/><Button Content="- V" Background="#333" Click="BlueAdvMinus_Click"/></UniformGrid>
                        <TextBlock Text="{Binding BluePenalty, StringFormat=Punições: {0}}" FontSize="20" Margin="0,12,0,0"/>
                        <UniformGrid Columns="2"><Button Content="+ P" Background="#D71920" Click="BluePenPlus_Click"/><Button Content="- P" Background="#333" Click="BluePenMinus_Click"/></UniformGrid>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Background="White" CornerRadius="8" Padding="14" Margin="8,0,0,0">
                    <StackPanel>
                        <TextBlock Text="BRANCO" Foreground="#111" FontSize="26" FontWeight="Bold"/>
                        <TextBlock Text="{Binding RedScore, StringFormat=Pontuação geral: {0}}" Foreground="#111" FontSize="20"/>
                        <UniformGrid Columns="3">
                            <Button Content="+2" Background="#8C1111" Click="Red2_Click"/><Button Content="+3" Background="#8C1111" Click="Red3_Click"/><Button Content="+4" Background="#8C1111" Click="Red4_Click"/>
                            <Button Content="-2" Background="#333" Click="RedMinus2_Click"/><Button Content="-3" Background="#333" Click="RedMinus3_Click"/><Button Content="-4" Background="#333" Click="RedMinus4_Click"/>
                        </UniformGrid>
                        <TextBlock Text="{Binding RedAdvantage, StringFormat=Vantagens: {0}}" Foreground="#111" FontSize="20" Margin="0,12,0,0"/>
                        <UniformGrid Columns="2"><Button Content="+ V" Background="#D79C22" Click="RedAdvPlus_Click"/><Button Content="- V" Background="#333" Click="RedAdvMinus_Click"/></UniformGrid>
                        <TextBlock Text="{Binding RedPenalty, StringFormat=Punições: {0}}" Foreground="#111" FontSize="20" Margin="0,12,0,0"/>
                        <UniformGrid Columns="2"><Button Content="+ P" Background="#D71920" Click="RedPenPlus_Click"/><Button Content="- P" Background="#333" Click="RedPenMinus_Click"/></UniformGrid>
                    </StackPanel>
                </Border>
            </Grid>

            <Border Background="Black" CornerRadius="8" Padding="18" Margin="0,18,0,0">
                <StackPanel>
                    <TextBlock Text="{Binding TimeText}" Foreground="#39FF14" FontSize="64" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <UniformGrid Columns="4">
                        <Button Content="INICIAR" Background="#21B31B" Click="Start_Click"/>
                        <Button Content="PAUSAR" Background="#D79C22" Click="Pause_Click"/>
                        <Button Content="RESET" Background="#333" Click="ResetTime_Click"/>
                        <Button Content="ENCERRAR" Background="#D71920" Click="End_Click"/>
                    </UniformGrid>
                    <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                        <TextBox x:Name="MinutesBox" Text="5" Width="80"/>
                        <TextBlock Text="minutos" VerticalAlignment="Center" Margin="8,0"/>
                        <Button Content="APLICAR TEMPO" Background="#0D47A1" Click="ApplyTime_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Background="#171717" BorderBrush="#333" BorderThickness="1" CornerRadius="8" Padding="14" Margin="0,18,0,0">
                <StackPanel>
                    <TextBlock Text="Resultado / Vencedor" FontSize="22" FontWeight="Bold" Margin="0,0,0,10"/>
                    <TextBlock Text="Em empate, escolha o vencedor manualmente ou exiba empate com os dois nomes." Foreground="#BDBDBD" FontSize="15" Margin="0,0,0,10"/>
                    <UniformGrid Columns="3">
                        <Button Content="VENCEDOR AZUL" Background="#0D47A1" Click="WinnerBlue_Click"/>
                        <Button Content="VENCEDOR BRANCO" Background="#B71C1C" Click="WinnerRed_Click"/>
                        <Button Content="EXIBIR EMPATE" Background="#D79C22" Click="Draw_Click"/>
                    </UniformGrid>
                    <UniformGrid Columns="3" Margin="0,14,0,0">
                        <Button Content="NOVA LUTA" Background="#0D47A1" Click="NewMatch_Click"/>
                        <Button Content="SALVAR E LIBERAR PAINEL" Background="#21B31B" Click="ReleasePanel_Click"/>
                        <Button Content="MOSTRAR VENCEDOR AUTO" Background="#D79C22" Click="Champion_Click"/>
                    </UniformGrid>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Window>
