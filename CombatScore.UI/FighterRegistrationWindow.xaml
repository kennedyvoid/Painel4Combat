<Window x:Class="CombatScore.UI.FighterRegistrationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="4Combat - Cadastro e Chamada de Lutadores"
        Width="1240"
        Height="790"
        Background="#101010"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="FontSize" Value="17"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="Margin" Value="0,5,0,12"/>
            <Setter Property="Background" Value="#181818"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#444"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="FontSize" Value="17"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="Margin" Value="0,5,0,12"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
    </Window.Resources>

    <Grid Margin="22">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="380"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Background="#171717" BorderBrush="#333" BorderThickness="1" CornerRadius="8" Padding="18">
            <ScrollViewer>
                <StackPanel>
                    <TextBlock Text="CADASTRO DE LUTADORES" Foreground="#FFD600" FontSize="26" FontWeight="Bold" Margin="0,0,0,18"/>

                    <TextBlock Text="Nome"/>
                    <TextBox x:Name="NameBox"/>

                    <TextBlock Text="Academia"/>
                    <TextBox x:Name="TeamBox"/>

                    <TextBlock Text="Sexo"/>
                    <ComboBox x:Name="GenderBox" SelectedIndex="0">
                        <ComboBoxItem Content="Masculino"/>
                        <ComboBoxItem Content="Feminino"/>
                    </ComboBox>

                    <TextBlock Text="Categoria"/>
                    <TextBox x:Name="CategoryBox" Text="Adulto / Peso Médio"/>

                    <TextBlock Text="Faixa"/>
                    <ComboBox x:Name="BeltBox" SelectedIndex="0">
                        <ComboBoxItem Content="Branca"/>
                        <ComboBoxItem Content="Azul"/>
                        <ComboBoxItem Content="Roxa"/>
                        <ComboBoxItem Content="Marrom"/>
                        <ComboBoxItem Content="Preta"/>
                    </ComboBox>

                    <Button Content="ADICIONAR LUTADOR" Background="#0D47A1" Height="48" Click="AddFighter_Click"/>
                    <Button Content="REMOVER SELECIONADO" Background="#B71C1C" Height="48" Click="RemoveFighter_Click"/>

                    <Border Height="1" Background="#333" Margin="0,20,0,18"/>

                    <TextBlock Text="GERAÇÃO DAS CHAVES" Foreground="#FFD600" FontSize="22" FontWeight="Bold"/>
                    <CheckBox x:Name="MixedGenerationBox"
                              Content="Geração mista: permite masculino x feminino, mantendo a regra da mesma faixa"
                              Foreground="White"
                              FontSize="15"
                              Margin="0,10,0,12"/>

                    <Button Content="GERAR CHAVES" Background="#21B31B" Height="48" Click="GenerateBrackets_Click"/>
                    <Button Content="ABRIR EXIBIÇÃO DAS CHAVES" Background="#333333" Height="48" Click="OpenBracketDisplay_Click"/>

                    <Border Height="1" Background="#333" Margin="0,20,0,18"/>

                    <TextBlock Text="CHAMADA PARA O PAINEL" Foreground="#FFD600" FontSize="22" FontWeight="Bold"/>
                    <TextBlock Text="Selecione dois lutadores na lista e clique para chamar. O primeiro vai para Azul e o segundo para Branco." Foreground="#BDBDBD" TextWrapping="Wrap" Margin="0,8,0,12"/>

                    <Button Content="CHAMAR SELECIONADOS" Background="#D79C22" Height="52" Click="CallSelected_Click"/>
                    <Button Content="CHAMAR PRÓXIMA CHAVE" Background="#21B31B" Height="52" Click="CallNextBracket_Click"/>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <Grid Grid.Column="1" Margin="18,0,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="285"/>
            </Grid.RowDefinitions>

            <Border Background="#171717" BorderBrush="#333" BorderThickness="1" CornerRadius="8" Padding="12">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="LISTA DE LUTADORES" Foreground="#FFD600" FontSize="24" FontWeight="Bold" Margin="0,0,0,12"/>

                    <DataGrid x:Name="FightersGrid"
                              AutoGenerateColumns="False"
                              SelectionMode="Extended"
                              IsReadOnly="True"
                              Background="#181818"
                              Foreground="White"
                              RowBackground="#202020"
                              AlternatingRowBackground="#151515"
                              GridLinesVisibility="None"
                              FontSize="15">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Nome" Binding="{Binding Nome}" Width="2*"/>
                            <DataGridTextColumn Header="Academia" Binding="{Binding Academia}" Width="2*"/>
                            <DataGridTextColumn Header="Sexo" Binding="{Binding Sexo}" Width="1*"/>
                            <DataGridTextColumn Header="Categoria" Binding="{Binding Categoria}" Width="1.5*"/>
                            <DataGridTextColumn Header="Faixa" Binding="{Binding Faixa}" Width="1*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>

            <Border Grid.Row="1" Background="#171717" BorderBrush="#333" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,16,0,0">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
                        <TextBlock Text="CHAVES GERADAS" Foreground="#FFD600" FontSize="24" FontWeight="Bold"/>
                        <TextBlock Text="Selecione uma luta abaixo e clique em CHAMAR LUTA SELECIONADA, ou dê duplo clique na linha." Foreground="#BDBDBD" FontSize="14" TextWrapping="Wrap" Margin="0,4,0,8"/>
                        <Button Content="CHAMAR LUTA SELECIONADA" Background="#21B31B" Height="42" HorizontalAlignment="Left" Click="CallSelectedBracket_Click"/>
                    </StackPanel>

                    <DataGrid x:Name="BracketsGrid"
                              AutoGenerateColumns="False"
                              SelectionMode="Single"
                              MouseDoubleClick="BracketsGrid_MouseDoubleClick"
                              IsReadOnly="True"
                              Background="#181818"
                              Foreground="White"
                              RowBackground="#202020"
                              AlternatingRowBackground="#151515"
                              GridLinesVisibility="None"
                              FontSize="15">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="#" Binding="{Binding Numero}" Width="55"/>
                            <DataGridTextColumn Header="Fase" Binding="{Binding Fase}" Width="120"/>
                            <DataGridTextColumn Header="Categoria" Binding="{Binding Categoria}" Width="150"/>
                            <DataGridTextColumn Header="Faixa" Binding="{Binding Faixa}" Width="90"/>
                            <DataGridTextColumn Header="Sexo" Binding="{Binding Sexo}" Width="90"/>
                            <DataGridTextColumn Header="Azul" Binding="{Binding LutadorAzul}" Width="*"/>
                            <DataGridTextColumn Header="Branco" Binding="{Binding LutadorBranco}" Width="*"/>
                            <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="120"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
