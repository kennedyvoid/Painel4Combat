<Window x:Class="CombatScore.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="4Combat"
        Width="900"
        Height="560"
        Background="#0B0B0B"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="Margin" Value="6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="#0D47A1"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#181818"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#444"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Margin" Value="6"/>
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="95"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Background="Black" CornerRadius="8">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0">
                <Image Source="Assets/logo.jpg" Height="55" Margin="0,0,20,0"/>
                <TextBlock Text="4COMBAT" FontSize="42" FontWeight="Bold"/>
                <TextBlock Text="  |  PAINEL DE COMPETIÇÃO" Foreground="#FFD600" FontSize="24" FontWeight="Bold" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Background="#151515" BorderBrush="#333" BorderThickness="1" CornerRadius="8" Margin="0,18,0,0" Padding="28">
            <StackPanel>
                <TextBlock Text="Configuração do tatame" FontSize="28" FontWeight="Bold"/>
                <TextBlock Text="Escolha se este painel será do Tatame 1 ou Tatame 2. O sistema abrirá apenas um painel público e uma tela de configuração." Foreground="#BDBDBD" FontSize="17" Margin="0,8,0,18"/>

                <TextBlock Text="Número do tatame" FontSize="20" FontWeight="Bold"/>
                <ComboBox x:Name="MatCombo" SelectedIndex="0" FontSize="22" Padding="10" Margin="0,8,0,22">
                    <ComboBoxItem Content="1"/>
                    <ComboBoxItem Content="2"/>
                </ComboBox>

                <Button Content="ABRIR PAINEL E CONFIGURAÇÃO" Background="#21B31B" Height="58" Click="OpenTatame_Click"/>
                <Button Content="FECHAR PAINÉIS" Background="#B71C1C" Height="58" Click="ClosePanels_Click"/>

                <TextBlock x:Name="StatusText" Text="Nenhum painel aberto." Foreground="#FFD600" FontSize="20" FontWeight="Bold" Margin="0,25,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
